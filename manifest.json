{
  "manifest_version": 3,
  "name": "Global Auto-Reply",
  "version": "1.0",
  "description": "Automatically reads your X feed and posts human-like replies using AI.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "*://*.twitter.com/*",
    "*://*.x.com/*",
    "https://api.groq.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.twitter.com/*", "*://*.x.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
